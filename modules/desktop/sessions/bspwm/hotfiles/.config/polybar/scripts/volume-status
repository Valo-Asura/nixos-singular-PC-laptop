#!/usr/bin/env bash
set -euo pipefail

line="$(amixer sget Master 2>/dev/null | awk -F'[][]' '/Right:|Mono:/ && NF > 1 { print $2, $4; exit }')"
percent="$(printf '%s\n' "$line" | awk '{ gsub(/%/, "", $1); print $1 }')"
state="$(printf '%s\n' "$line" | awk '{ print $2 }')"

if [ -z "${percent:-}" ]; then
  echo "󰕾 --"
elif [ "${state:-off}" = "off" ]; then
  echo "󰝟 ${percent}%"
elif [ "$percent" -ge 60 ]; then
  echo "󰕾 ${percent}%"
elif [ "$percent" -ge 20 ]; then
  echo "󰖀 ${percent}%"
else
  echo "󰕿 ${percent}%"
fi
