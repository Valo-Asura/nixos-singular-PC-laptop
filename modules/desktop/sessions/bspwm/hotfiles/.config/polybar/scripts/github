#!/usr/bin/env bash
set -euo pipefail

if [ -z "${GITHUB_TOKEN:-}" ]; then
    echo "0"
    exit 0
fi

notifications="$(
    curl -fsS \
        -H "Authorization: Bearer ${GITHUB_TOKEN}" \
        -H "Accept: application/vnd.github+json" \
        https://api.github.com/notifications 2>/dev/null \
        | jq '[.[] | select(.unread == true)] | length' 2>/dev/null \
        || printf 0
)"

if [ "${notifications:-0}" -gt 0 ]; then
    echo "$notifications"
else
    echo "0"
fi
