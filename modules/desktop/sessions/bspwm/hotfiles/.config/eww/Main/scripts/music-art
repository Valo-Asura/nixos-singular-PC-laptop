#!/usr/bin/env bash
set -euo pipefail

tmp_dir="$HOME/.config/eww/Main/images"
tmp_temp_path="$tmp_dir/temp.png"
mkdir -p "$tmp_dir"

default_art="Main/images/default-music.svg"
players="spotify,%any,mpd,firefox,chromium,brave"
artlink="$(playerctl -p "$players" metadata mpris:artUrl 2>/dev/null | head -n 1 | sed -e 's/open.spotify.com/i.scdn.co/g' || true)"
browser_art="$(playerctl metadata mpris:artUrl 2>/dev/null | head -n 1 | sed 's|file://||g' || true)"

if [[ "$artlink" =~ ^https?:// ]]; then
	if curl -fsSL "$artlink" --output "$tmp_temp_path"; then
		echo "$tmp_temp_path"
		exit 0
	fi
elif [[ -n "$browser_art" && -f "$browser_art" ]]; then
	cp "$browser_art" "$tmp_temp_path"
	echo "$tmp_temp_path"
	exit 0
fi

echo "$default_art"
