#!/usr/bin/env bash
set -euo pipefail

powered="no"
if bluetoothctl show 2>/dev/null | grep -q "Powered: yes"; then
  powered="yes"
fi

connected_info="$(echo info | bluetoothctl 2>/dev/null || true)"

toggle() {
  if [ "$powered" = "yes" ]; then
    bluetoothctl power off
    notify-send --icon=bluetooth-offline --urgency=normal "Bluetooth" "Bluetooth has been turned off."
  else
    bluetoothctl power on
    notify-send --icon=bluetooth-active --urgency=normal "Bluetooth" "Bluetooth has been turned on."
  fi
}

icon() {
  if [ "$powered" != "yes" ]; then
    echo "󰂲"
  elif printf '%s\n' "$connected_info" | grep -q '^Device'; then
    echo "󰂱"
  else
    echo "󰂯"
  fi
}

class() {
  if [ "$powered" = "yes" ]; then
    echo "󰂯"
  else
    echo "󰂲"
  fi
}

status() {
  if [ "$powered" != "yes" ]; then
    echo "Off"
  elif printf '%s\n' "$connected_info" | grep -q '^Device'; then
    printf '%s\n' "$connected_info" | awk -F': ' '/Alias:/ { print $2; exit }'
  else
    echo "On"
  fi
}

battery() {
  if [ "$powered" != "yes" ]; then
    echo "Currently Off"
    return
  fi

  local device
  device="$(upower -e 2>/dev/null | grep -E 'headset|headphones|keyboard|mouse' | head -n 1 || true)"

  if [ -z "$device" ]; then
    echo "Not Connected"
    return
  fi

  local percent
  percent="$(upower -i "$device" 2>/dev/null | awk '/percentage:/ { print $2; exit }')"
  if [ -n "$percent" ]; then
    echo "Battery Level: $percent"
  else
    echo "Connected"
  fi
}

case "${1:-}" in
  --status) status ;;
  --icon) icon ;;
  --toggle) toggle ;;
  --class) class ;;
  --battery) battery ;;
esac
