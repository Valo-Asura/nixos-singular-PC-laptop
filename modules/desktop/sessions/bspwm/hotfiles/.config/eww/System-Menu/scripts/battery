#!/usr/bin/env bash
set -euo pipefail

battery=""
for candidate in /sys/class/power_supply/BAT*; do
  if [ -d "$candidate" ]; then
    battery="$candidate"
    break
  fi
done

if [ -z "$battery" ]; then
  case "${1:-}" in
    -l) echo "No battery" ;;
    -c) echo " " ;;
    -i) echo " " ;;
  esac
  exit 0
fi

level="$(cat "$battery/capacity" 2>/dev/null || printf 0)"
state="$(cat "$battery/status" 2>/dev/null || printf Unknown)"

icon() {
  local prefix=""
  case "$state" in
    Charging|Full) prefix=" " ;;
  esac

  if [ "$level" -ge 80 ]; then
    echo "${prefix}  "
  elif [ "$level" -ge 60 ]; then
    echo "${prefix}  "
  elif [ "$level" -ge 40 ]; then
    echo "${prefix}  "
  elif [ "$level" -ge 20 ]; then
    echo "${prefix}  "
  else
    echo "${prefix}  "
  fi
}

class() {
  case "$state" in
    Charging|Full) echo "" ;;
    *) echo " " ;;
  esac
}

case "${1:-}" in
  -l) echo "${level}%" ;;
  -c) class ;;
  -i) icon ;;
esac
