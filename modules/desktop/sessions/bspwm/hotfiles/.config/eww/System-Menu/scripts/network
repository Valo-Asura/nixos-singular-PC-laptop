#!/usr/bin/env bash
set -euo pipefail

wifi_enabled="$(nmcli -t -f WIFI general 2>/dev/null || printf disabled)"
active_wifi="$(
  nmcli -t -f ACTIVE,SSID,SIGNAL dev wifi 2>/dev/null \
    | awk -F: '$1 == "yes" { print; exit }'
)"
ssid="$(printf '%s\n' "$active_wifi" | awk -F: '{ print $2 }')"
strength="$(printf '%s\n' "$active_wifi" | awk -F: '{ print $3 }')"

if ! [[ "${strength:-}" =~ ^[0-9]+$ ]]; then
  strength=0
fi

toggle() {
  if [ "$wifi_enabled" = "enabled" ]; then
    nmcli radio wifi off
    notify-send --icon=network-wireless-offline --urgency=normal "Wi-Fi" "Wi-Fi has been turned off."
  else
    nmcli radio wifi on
    notify-send --icon=network-wireless --urgency=normal "Wi-Fi" "Wi-Fi has been turned on."
  fi
}

icon() {
  if [ "$wifi_enabled" != "enabled" ]; then
    echo "󰤭"
  elif [ "$strength" -ge 80 ]; then
    echo "󰤨"
  elif [ "$strength" -ge 60 ]; then
    echo "󰤥"
  elif [ "$strength" -ge 40 ]; then
    echo "󰤢"
  elif [ "$strength" -ge 20 ]; then
    echo "󰤟"
  else
    echo "󰤯"
  fi
}

status() {
  if [ "$wifi_enabled" != "enabled" ]; then
    echo "Off"
  elif [ -n "$ssid" ]; then
    echo "$ssid"
  else
    echo "Disconnected"
  fi
}

class() {
  if [ "$wifi_enabled" = "enabled" ] && [ -n "$ssid" ]; then
    echo "connected"
  else
    echo "disconnected"
  fi
}

case "${1:-}" in
  --toggle) toggle ;;
  --icon) icon ;;
  --status) status ;;
  --class) class ;;
esac
